# Required public Supabase configuration for the browser app.
# These are Vite-exposed public values; do not place service-role keys or secrets here.
VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your-supabase-anon-key

# Optional local-development only flag. Production builds must not enable demo auth.
# VITE_ENABLE_DEMO_AUTH=false
